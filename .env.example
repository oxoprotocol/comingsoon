# Ethereum / Sepolia
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Bridge Relayer
BRIDGE_CONTRACT_ADDRESS=0xYOUR_BRIDGE_CONTRACT_ADDRESS
SIGNER_PRIVATE_KEY=0xYOUR_SIGNER_PRIVATE_KEY

# BlockCypher (BTC Testnet)
BLOCKCYPHER_TOKEN=YOUR_BLOCKCYPHER_TOKEN

# Ngrok / Backend URL (güncelle her oturumda)
NGROK_PUBLIC_URL=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app

# Bitcoin Multisig Keys (WIF format, testnet)
KEY_1_WIF=YOUR_WIF_KEY_1
KEY_2_WIF=YOUR_WIF_KEY_2
KEY_3_WIF=YOUR_WIF_KEY_3

# Güvenlik
WEBHOOK_SECRET=your_random_secret_here
ADMIN_API_SECRET=your_random_admin_secret_here
MAX_MINT_PER_TX_SATS=100000000  # 1 BTC — tek işlem limiti (mainnet'te artır)

# Sunucu
PORT=3001

# TEST_MODE=true (sadece local test için - webhook TX doğrulamasını atlar)
# TEST_MODE=true

# PostgreSQL (Production) — neon.tech ücretsiz tier önerilir
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
